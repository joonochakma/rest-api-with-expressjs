{
  "name": "rest-api-with-expressjs",
  "version": "1.0.0",
  "description": "Production-ready REST API with Express.js, TypeScript, and MongoDB",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon",
    "build": "tsc",
    "setup:dynamodb": "ts-node scripts/create-table.ts",
    "docker:build": "docker build -t rest-api .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "rest-api",
    "express",
    "typescript",
    "mongodb",
    "authentication"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.4",
    "@types/mongoose": "^5.11.97",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1004.0",
    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lodash": "^4.17.21",
    "mongodb": "^6.7.0",
    "mongoose": "^8.4.0",
    "uuid": "^13.0.0"
  }
}
